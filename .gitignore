# OS / editor
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# Python
__pycache__/
*.py[cod]
.venv/
venv/

# Node
node_modules/

# Scratch / build fixtures
/tmp/
*.log

# Local authoring prompts (source material, intentionally not committed)
*.prompt.md

# Stale git-repo backup left by sandbox (safe to delete on your machine)
.git.trash*/

# Test/benchmark/eval artifact payloads: kept locally under
# docs/<group>/<skill>/artifacts/, never committed (owner policy 2026-07-21).
# Each artifacts/README.md IS committed — it documents what exists locally
# and how to regenerate it.
docs/*/*/artifacts/*
!docs/*/*/artifacts/README.md
# Hand-authored eval definitions are inputs (needed to reproduce runs), not outputs:
!docs/*/*/artifacts/evals.json
!docs/*/*/artifacts/description-trigger-eval.json

# Local sandbox/session litter
.claude/
